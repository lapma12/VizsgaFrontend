# 1. Build stage – Node + npm
FROM node:20-alpine AS build
WORKDIR /app

# Csak a lock fájlokat és package.json-t másoljuk először a cache miatt
COPY package.json package-lock.json* pnpm-lock.yaml* yarn.lock* ./

# Ha nincs lockfile, az npm így is lefut, csak warningot dobhat
RUN npm install

# Most jöhet a teljes forrás
COPY . .

# Vite: ez dist mappába fog buildelni
RUN npm run build


# 2. Runtime stage – Nginx szolgálja ki a statikus fájlokat
FROM nginx:alpine

# Töröljük az alapértelmezett confot
RUN rm /etc/nginx/conf.d/default.conf

# Saját nginx config
COPY nginx.conf /etc/nginx/conf.d/default.conf

# Statikus build bemásolása
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
